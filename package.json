{
	"name": "@blagoja/ts-dlp",
	"version": "0.1.0",
	"description": "A human readable TypeScript wrapper for yt-dlp",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsx src/index.ts",
		"lint": "eslint src",
		"prepublishOnly": "npm run build"
