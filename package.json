	},
	"license": "ISC",
	"type": "module",
	"devDependencies": {
		"@types/node": "^25.9.1",
		"typescript-eslint": "^8.60.0",
		"eslint": "^10.4.0",
		"jiti": "^2.7.0",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"execa": "^9.6.1"
	}
}
